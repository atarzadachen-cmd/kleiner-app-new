import React, { useState } from 'react';

const CATS = [
  { id: 'all',     label: 'הכל' },
  { id: 'dairy',   label: '🥛 חלב וביצים' },
  { id: 'produce', label: '🥦 פירות וירקות' },
  { id: 'bakery',  label: '🍞 מאפיות' },
  { id: 'baby',    label: '👶 תינוק' },
];

export default function ShoppingScreen({ shopping, onToggle }) {
  const [cat, setCat] = useState('all');

  const filtered = cat === 'all' ? shopping : shopping.filter(s => s.cat === cat);
  const remaining = filtered.filter(s => !s.done).length;

  return (
    <div className="screen" style={{ background: 'rgba(12,6,30,0.97)', backdropFilter: 'blur(28px)', WebkitBackdropFilter: 'blur(28px)' }}>
      <div className="ss-topbar">
        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
          <div className="ss-title">🛒 רשימת קניות</div>
          <span style={{ fontSize: 12, padding: '4px 12px', background: 'rgba(255,255,255,0.1)', borderRadius: 12, color: 'rgba(255,255,255,0.6)', fontWeight: 600 }}>{remaining} נותרו</span>
        </div>
      </div>

      <div className="s-body" style={{ paddingTop: 0 }}>
        {/* Category filter */}
        <div style={{ display: 'flex', gap: 8, overflowX: 'auto', padding: '14px 20px 0', scrollbarWidth: 'none' }}>
          {CATS.map(c => (
            <button key={c.id} className={`chip${cat === c.id ? ' on' : ''}`} style={{ whiteSpace: 'nowrap', flexShrink: 0 }} onClick={() => setCat(c.id)}>{c.label}</button>
          ))}
        </div>

        {/* List */}
        <div className="glass" style={{ margin: '12px 20px 0', overflow: 'hidden' }}>
          {filtered.map((s, i) => (
            <div key={s.id} style={{ display: 'flex', alignItems: 'center', gap: 11, padding: '12px 15px', borderBottom: i < filtered.length - 1 ? '1px solid rgba(255,255,255,0.06)' : 'none', opacity: s.done ? 0.4 : 1, transition: 'opacity 0.2s' }}>
              <div
                style={{ width: 24, height: 24, borderRadius: 8, border: `2px solid ${s.done ? '#60D4A0' : 'rgba(255,255,255,0.2)'}`, display: 'flex', alignItems: 'center', justifyContent: 'center', cursor: 'pointer', flexShrink: 0, fontSize: 13, background: s.done ? '#60D4A0' : 'rgba(255,255,255,0.04)', color: '#fff', transition: 'all 0.2s' }}
                onClick={() => onToggle(s.id)}
              >{s.done ? '✓' : ''}</div>
              <span style={{ fontSize: 22 }}>{s.emoji}</span>
              <div style={{ flex: 1 }}>
                <div style={{ fontSize: 14, color: 'rgba(255,255,255,0.82)', fontWeight: 500 }}>{s.name}</div>
                <div style={{ fontSize: 11, color: 'var(--muted)', marginTop: 1 }}>{s.sub}</div>
              </div>
              <span style={{ fontSize: 12, fontWeight: 700, color: 'rgba(255,255,255,0.5)', background: 'rgba(255,255,255,0.08)', padding: '3px 9px', borderRadius: 8 }}>{s.qty}</span>
            </div>
          ))}
        </div>

        <button className="add-btn">＋ הוסף פריט</button>
      </div>
    </div>
  );
}
